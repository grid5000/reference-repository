<%
  CLUSTER_NAME = "gres"
  NODES_NUMBER = 7
  SITE_IPV4_INDEX = 65
  # MAC addresses declaration
  MAC_ETH0_LIST = %w(
    d4:04:e6:08:27:12
    d4:04:e6:07:d5:3a
    d4:04:e6:08:8c:52
    d4:04:e6:07:cd:fc
    d4:04:e6:08:1b:0c
    d4:04:e6:07:d5:ee
  )

  MAC_BMC_LIST = %w(
    7c:a6:2a:4e:5a:e8
    7c:a6:2a:4e:5a:e4
    7c:a6:2a:4e:5b:f4
    7c:a6:2a:4e:5e:dc
    5c:ed:8c:01:d8:0a
    7c:a6:2a:4e:5b:36
  )

  MAC_ETH1_LIST = %w(
    d4:04:e6:08:27:13
    d4:04:e6:07:d5:3b
    d4:04:e6:08:8c:53
    d4:04:e6:07:cd:fd
    d4:04:e6:08:1b:0d
    d4:04:e6:07:d5:ef
  )

  SERIAL_LIST = %w(
    CZ24310FCB
    CZ24310FC9
    CZ24310F9Y
    CZ24310FCF
    CZ24310FCD
    CZ24310FC8
  )
%>
---
nodes:
<% (2..NODES_NUMBER).each { |i| %>
 <%= CLUSTER_NAME %>-<%= i %>:
    architecture:
      nb_procs: 2
      nb_cores: 48
      nb_threads: 96
      platform_type: x86_64
      cpu_core_numbering: contiguous 
    bios:
      release_date: 12/08/2023
      vendor: HPE
      version: 1.56
    bmc_version: '1.59'
    chassis:
      manufacturer: HPE
      name: ProLiant DL385 Gen11
      serial: <%= SERIAL_LIST[i - 1] %>
    gpu_devices:
      nvidia0:
        cpu_affinity: 1
        device: "/dev/nvidia0"
        memory: 48305799168
        model: L40S
        power_default_limit: 350.00 W
        vbios_version: 95.02.66.00.02
        vendor: Nvidia
      nvidia1:
        cpu_affinity: 1
        device: "/dev/nvidia1"
        memory: 48305799168
        model: L40S
        power_default_limit: 350.00 W
        vbios_version: 95.02.66.00.02
        vendor: Nvidia
    main_memory:
      ram_size: 549755813888
    memory_devices:
      dimm_proc 1 dimm 4:
        size: 68719476736
        technology: dram
      dimm_proc 1 dimm 6:
        size: 68719476736
        technology: dram
      dimm_proc 1 dimm 7:
        size: 68719476736
        technology: dram
      dimm_proc 1 dimm 9:
        size: 68719476736
        technology: dram
      dimm_proc 2 dimm 4:
        size: 68719476736
        technology: dram
      dimm_proc 2 dimm 6:
        size: 68719476736
        technology: dram
      dimm_proc 2 dimm 7:
        size: 68719476736
        technology: dram
      dimm_proc 2 dimm 9:
        size: 68719476736
        technology: dram
    processor:
      model: AMD EPYC
      other_description: AMD EPYC 9254 24-Core Processor
      vendor: AMD
      version: 9254
      cache_l1d: 32768
      cache_l1i: 32768
      cache_l2: 1048576
      cache_l3: 33554432
      instruction_set: x86-64
      microcode: '0xa101144'
      ht_capable: true
    operating_system:
      cstate_driver: acpi_idle
      cstate_governor: menu
      ht_enabled: true
      pstate_driver: acpi-cpufreq
      pstate_governor: performance
      turboboost_enabled: true      
    network_adapters:
      bmc:
        management: true
        mac: <%= MAC_BMC_LIST[i - 1] %>
        ip: 172.17.<%= SITE_IPV4_INDEX %>.<%= i %>
      eth0:
        interface: Ethernet
        management: false
        driver: bnxt_en
        name: ens22f0np0
        rate: 25000000000
        mac: <%= MAC_ETH0_LIST[i - 1] %>
        ip: 172.16.<%= SITE_IPV4_INDEX %>.<%= i %>
        firmware_version: 228.0.116.0/pkg 228.1.111.0
        model: BCM57414 NetXtreme-E 10Gb/25Gb RDMA Ethernet Controller
        sriov: false
        sriov_totalvfs: 0
        vendor: Broadcom Inc. and subsidiaries
      eth1:
        driver: bnxt_en
        firmware_version: 228.0.116.0/pkg 228.1.111.0
        interface: Ethernet
        mac: <%= MAC_ETH1_LIST[i - 1] %>
        management: false
        model: BCM57414 NetXtreme-E 10Gb/25Gb RDMA Ethernet Controller
        name: ens22f1np1
        sriov: false
        sriov_totalvfs: 0
        vendor: Broadcom Inc. and subsidiaries
    storage_devices:
      pci-0000:c5:00.0-nvme-1:
        by_path: "/dev/disk/by-path/pci-0000:c5:00.0-nvme-1"
        model: MO006400KYDND
        size: 6401252745216
        storage: SSD
    supported_job_types:
      virtual: amd-v
<% } %>
